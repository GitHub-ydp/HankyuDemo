  <diagram name="3. 用户操作3步测试指南" id="page3">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title3" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#1A237E&quot;&gt;测试指南 — 3 步完成自动填入&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px;font-weight:normal;&quot; color=&quot;#666&quot;&gt;访问 http://localhost:5173/pkg&lt;/font&gt;" vertex="1">
          <mxGeometry x="350" y="20" width="1000" height="60" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="s1_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=3;verticalAlign=top;fontSize=16;fontStyle=1;arcSize=5;" value="Step 1 — 上传" vertex="1">
          <mxGeometry x="80" y="120" width="480" height="460" as="geometry" />
        </mxCell>
        <mxCell id="s1_body" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=none;strokeColor=none;" value="&lt;b&gt;操作：&lt;/b&gt;&lt;br&gt;1. 打开 http://localhost:5173&lt;br&gt;2. 左侧菜单点 &quot;入札自動填入&quot;&lt;br&gt;3. 拖拽或点击上传框&lt;br&gt;&lt;br&gt;&lt;b&gt;测试文件：&lt;/b&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot;&gt;资料/2026.04.02/&lt;br&gt;Customer A (Air)/&lt;br&gt;Customer A (Air)/&lt;br&gt;2-①.xlsx&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;预期结果：&lt;/b&gt;&lt;br&gt;• 成功提示: &quot;识别到 5 个发地段、26 条航线&quot;&lt;br&gt;• 自动跳转到 Step 2 页面&lt;br&gt;&lt;br&gt;&lt;b&gt;后端操作：&lt;/b&gt;&lt;br&gt;• 文件保存到 uploads/pkg/&#123;session_id&#125;/&lt;br&gt;• pkg_parser.py 解析结构&lt;br&gt;• 返回 session_id + parse_result" vertex="1">
          <mxGeometry x="100" y="160" width="440" height="400" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="s2_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=3;verticalAlign=top;fontSize=16;fontStyle=1;arcSize=5;" value="Step 2 — 确认解析 + 自动填入" vertex="1">
          <mxGeometry x="590" y="120" width="480" height="460" as="geometry" />
        </mxCell>
        <mxCell id="s2_body" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=none;strokeColor=none;" value="&lt;b&gt;页面展示：&lt;/b&gt;&lt;br&gt;• 顶部 Alert 显示文件名 + 期间&lt;br&gt;• Collapse 折叠面板展示 5 段发地&lt;br&gt;&amp;nbsp;&amp;nbsp;PVG (上海) - 6 航线&lt;br&gt;&amp;nbsp;&amp;nbsp;NRT (日本) - 4 航线&lt;br&gt;&amp;nbsp;&amp;nbsp;TPE (台湾) - 4 航线&lt;br&gt;&amp;nbsp;&amp;nbsp;AMS (荷兰) - 6 航线&lt;br&gt;&amp;nbsp;&amp;nbsp;ICN (韩国) - 6 航线&lt;br&gt;• 每段下 Table 展示每条航线&lt;br&gt;&lt;br&gt;&lt;b&gt;操作：&lt;/b&gt;点击 &quot;自動填入&quot; 按钮&lt;br&gt;&lt;br&gt;&lt;b&gt;预期结果：&lt;/b&gt;&lt;br&gt;• 按钮 loading 几秒&lt;br&gt;• 成功提示: &quot;25/26 条航线已填入&quot;&lt;br&gt;• 跳转到 Step 3&lt;br&gt;&lt;br&gt;&lt;b&gt;检查点：&lt;/b&gt;&lt;br&gt;• 发地段识别是否完整&lt;br&gt;• 币种是否正确 (JPY/CNY/EUR/USD)&lt;br&gt;• 着地名称是否清晰" vertex="1">
          <mxGeometry x="610" y="160" width="440" height="400" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="s3_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=3;verticalAlign=top;fontSize=16;fontStyle=1;arcSize=5;" value="Step 3 — 查看结果 + 下载" vertex="1">
          <mxGeometry x="1100" y="120" width="520" height="460" as="geometry" />
        </mxCell>
        <mxCell id="s3_body" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=none;strokeColor=none;" value="&lt;b&gt;页面展示：&lt;/b&gt;&lt;br&gt;• 4 张统计卡:&lt;br&gt;&amp;nbsp;&amp;nbsp;总航线数 26&lt;br&gt;&amp;nbsp;&amp;nbsp;已填入 25&lt;br&gt;&amp;nbsp;&amp;nbsp;填入率 96%&lt;br&gt;&amp;nbsp;&amp;nbsp;平均置信度 ~95%&lt;br&gt;• 详情表 展示每条航线&lt;br&gt;&amp;nbsp;&amp;nbsp;状态 (filled / no_rate / already_filled)&lt;br&gt;&amp;nbsp;&amp;nbsp;置信度标签 (高/中/低)&lt;br&gt;&amp;nbsp;&amp;nbsp;原始值 → 填入值&lt;br&gt;&amp;nbsp;&amp;nbsp;Lead Time / Carrier&amp;Route&lt;br&gt;&lt;br&gt;&lt;b&gt;操作：&lt;/b&gt;点击 &quot;下载填入完成文件&quot;&lt;br&gt;&lt;br&gt;&lt;b&gt;验证填入准确度（对比 2-④.xlsx）：&lt;/b&gt;&lt;br&gt;• PVG→ATL 应为 49 CNY/kg&lt;br&gt;• PVG→MIA 应为 54 CNY/kg&lt;br&gt;• PVG→AMS 应为 ~41 CNY/kg&lt;br&gt;• PVG→SYD 应为 25 CNY/kg&lt;br&gt;• PVG→TPE 应为 13 CNY/kg&lt;br&gt;&lt;br&gt;&lt;b&gt;后端操作：&lt;/b&gt;&lt;br&gt;• 返回 FileResponse&lt;br&gt;• 文件名 filled_2-①.xlsx" vertex="1">
          <mxGeometry x="1120" y="160" width="480" height="400" as="geometry" />
        </mxCell>

        <!-- 步骤间箭头 -->
        <mxCell id="s_arrow1" parent="1" style="endArrow=classic;html=1;strokeColor=#1A237E;strokeWidth=3;" edge="1" source="s1_box" target="s2_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_arrow2" parent="1" style="endArrow=classic;html=1;strokeColor=#1A237E;strokeWidth=3;" edge="1" source="s2_box" target="s3_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== 底部提示 ====== -->
        <mxCell id="tip_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;arcSize=5;" value="&lt;b&gt;&#128161; 测试重点 &amp; 常见问题&lt;/b&gt;" vertex="1">
          <mxGeometry x="80" y="620" width="1540" height="280" as="geometry" />
        </mxCell>

        <mxCell id="tip1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;✓ 为什么 1 条没填入？&lt;/b&gt;&lt;br&gt;&lt;br&gt;LOCAL DELIVERY 示例行&lt;br&gt;模板里已有 750 JPY 数据&lt;br&gt;默认不覆盖已有值&lt;br&gt;&lt;br&gt;(可通过 overwrite 参数强制覆盖)" vertex="1">
          <mxGeometry x="100" y="660" width="240" height="220" as="geometry" />
        </mxCell>
        <mxCell id="tip2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;✓ 费率从哪里来？&lt;/b&gt;&lt;br&gt;&lt;br&gt;rate_db.py 硬编码 27 条&lt;br&gt;来源:&lt;br&gt;• Yang Jie 邮件成本价&lt;br&gt;• Nakamura S/R 邮件&lt;br&gt;• 2-④ 最终填入文件&lt;br&gt;&lt;br&gt;均为 Customer A 真实数据" vertex="1">
          <mxGeometry x="360" y="660" width="240" height="220" as="geometry" />
        </mxCell>
        <mxCell id="tip3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;⚠ 换其他客户文件会怎样？&lt;/b&gt;&lt;br&gt;&lt;br&gt;费率库只覆盖 Customer A&lt;br&gt;换 B/E/ニトリ 会出现&lt;br&gt;大量 &quot;无匹配费率&quot;&lt;br&gt;&lt;br&gt;这是预期的 Demo 局限&lt;br&gt;(真实上线需扩费率库)" vertex="1">
          <mxGeometry x="620" y="660" width="240" height="220" as="geometry" />
        </mxCell>
        <mxCell id="tip4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;⚠ 没有用 LLM？&lt;/b&gt;&lt;br&gt;&lt;br&gt;当前 parser 是规则式&lt;br&gt;(openpyxl + 正则)&lt;br&gt;&lt;br&gt;Customer A 格式固定&lt;br&gt;规则已够用&lt;br&gt;&lt;br&gt;向客户演示时&lt;br&gt;建议说 &quot;智能识别&quot;&lt;br&gt;不要说 &quot;大模型&quot;" vertex="1">
          <mxGeometry x="880" y="660" width="240" height="220" as="geometry" />
        </mxCell>
        <mxCell id="tip5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;⚠ Session 是内存的&lt;/b&gt;&lt;br&gt;&lt;br&gt;后端 _sessions dict&lt;br&gt;重启后丢失&lt;br&gt;&lt;br&gt;Demo 已跑过几次&lt;br&gt;(uploads/pkg/ 下 13 个目录)&lt;br&gt;&lt;br&gt;正式版应改为&lt;br&gt;Redis 或数据库" vertex="1">
          <mxGeometry x="1140" y="660" width="240" height="220" as="geometry" />
        </mxCell>
        <mxCell id="tip6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;&#128680; 重点检查项&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. 上传后跳转顺畅&lt;br&gt;2. 5 段全识别&lt;br&gt;3. 填入率 96%&lt;br&gt;4. 下载文件可打开&lt;br&gt;5. 与 2-④ 对比无误&lt;br&gt;&lt;br&gt;发现问题可直接&lt;br&gt;告诉我修复" vertex="1">
          <mxGeometry x="1400" y="660" width="200" height="220" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

