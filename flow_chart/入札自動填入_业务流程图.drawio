<mxfile host="Electron" agent="draw.io" version="29.6.1" pages="3">

  <diagram name="1. 人工流程 vs AI自动化对比" id="page1">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#1A237E&quot;&gt;入札自動填入 — 人工流程 vs AI 自動化対比&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px;font-weight:normal;&quot; color=&quot;#666&quot;&gt;以 Customer A（ミマキエンジニアリング）Air 入札案例为例&lt;/font&gt;" vertex="1">
          <mxGeometry x="350" y="20" width="1000" height="60" as="geometry" />
        </mxCell>

        <!-- ===== 上半部分: 人工流程 ===== -->
        <mxCell id="manual_lane" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;verticalAlign=top;fontSize=15;fontStyle=1;arcSize=3;" value="【現状】人工流程 — 耗时 2~5 天" vertex="1">
          <mxGeometry x="60" y="110" width="1580" height="340" as="geometry" />
        </mxCell>

        <!-- Step 1: 客户下发 -->
        <mxCell id="m1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;① 客户下发 PKG&lt;/b&gt;&lt;br&gt;&lt;br&gt;客户发送空白入札模板&lt;br&gt;Excel (2-①.xlsx)&lt;br&gt;&lt;br&gt;含 5 段发地 × 26 航线&lt;br&gt;(中国/日本/台湾/荷兰/韩国)" vertex="1">
          <mxGeometry x="90" y="160" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- Step 2: 营业拆解 -->
        <mxCell id="m2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;② 营业拆解航线&lt;/b&gt;&lt;br&gt;&lt;br&gt;日本营业 (福山等)&lt;br&gt;人工识别每个发地段&lt;br&gt;&lt;br&gt;按发地分别准备询价邮件&lt;br&gt;(每段一封)" vertex="1">
          <mxGeometry x="320" y="160" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- Step 3: 各地询价 -->
        <mxCell id="m3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;③ 各地采购询价&lt;/b&gt;&lt;br&gt;&lt;br&gt;邮件 → 上海购买部&lt;br&gt;邮件 → 台湾/韩国代理&lt;br&gt;邮件 → 荷兰代理&lt;br&gt;&lt;br&gt;(1-②-1/2/3 多轮往返)" vertex="1">
          <mxGeometry x="550" y="160" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- Step 4: 回复汇总 -->
        <mxCell id="m4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;④ 回复汇总&lt;/b&gt;&lt;br&gt;&lt;br&gt;Yang Jie 提供成本&lt;br&gt;Nakamura 确认 S/R&lt;br&gt;(1-②-3.msg)&lt;br&gt;&lt;br&gt;营业等待各地回复&lt;br&gt;1~3 个工作日" vertex="1">
          <mxGeometry x="780" y="160" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- Step 5: 手工填表 -->
        <mxCell id="m5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;⑤ 手工填入 Excel&lt;/b&gt;&lt;br&gt;&lt;br&gt;将邮件里的费率&lt;br&gt;一条一条复制到&lt;br&gt;模板对应栏位&lt;br&gt;&lt;br&gt;単価 / Lead Time /&lt;br&gt;Carrier&amp;Route" vertex="1">
          <mxGeometry x="1010" y="160" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- Step 6: 提交投标 -->
        <mxCell id="m6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;⑥ 回传客户&lt;/b&gt;&lt;br&gt;&lt;br&gt;填入完成的 Excel&lt;br&gt;(2-④.xlsx)&lt;br&gt;&lt;br&gt;邮件回复客户&lt;br&gt;(1-③.msg)" vertex="1">
          <mxGeometry x="1240" y="160" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- 时间轴提示 -->
        <mxCell id="m_time" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#C62828;" value="↑ 全程 2~5 天（等待询价回复是主要瓶颈）↑" vertex="1">
          <mxGeometry x="400" y="340" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- 痛点 -->
        <mxCell id="m_pain" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;arcSize=10;" value="&lt;b&gt;痛点:&lt;/b&gt; ① 多次邮件往返慢 ② 手工复制易出错 ③ 历史费率未复用 ④ 同一航线重复询价 ⑤ 格式差异需反复人工适配" vertex="1">
          <mxGeometry x="90" y="380" width="1350" height="50" as="geometry" />
        </mxCell>

        <!-- 箭头连接 -->
        <mxCell id="a_m1" parent="1" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="m1" target="m2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_m2" parent="1" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="m2" target="m3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_m3" parent="1" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="m3" target="m4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_m4" parent="1" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="m4" target="m5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_m5" parent="1" style="endArrow=classic;html=1;strokeColor=#C62828;strokeWidth=2;" edge="1" source="m5" target="m6"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== 下半部分: AI 自动化 ===== -->
        <mxCell id="ai_lane" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=top;fontSize=15;fontStyle=1;arcSize=3;" value="【Demo】AI 自動化流程 — 耗时 &lt;1 分钟" vertex="1">
          <mxGeometry x="60" y="490" width="1580" height="340" as="geometry" />
        </mxCell>

        <!-- AI Step 1: 上传 -->
        <mxCell id="a1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;① 上传 PKG&lt;/b&gt;&lt;br&gt;&lt;br&gt;营业拖拽客户发来的&lt;br&gt;空白模板 (2-①.xlsx)&lt;br&gt;&lt;br&gt;点击上传&lt;br&gt;(前端 PkgAutoFill 页面)" vertex="1">
          <mxGeometry x="90" y="540" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- AI Step 2: 解析 -->
        <mxCell id="a2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;② 自动解析结构&lt;/b&gt;&lt;br&gt;&lt;br&gt;pkg_parser.py&lt;br&gt;自动识别：&lt;br&gt;• 5 段发地 (Section)&lt;br&gt;• 26 条航线 (Lane)&lt;br&gt;• 币种 (JPY/CNY/EUR/USD)&lt;br&gt;• 费用类型" vertex="1">
          <mxGeometry x="320" y="540" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- AI Step 3: 查费率 -->
        <mxCell id="a3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;③ 查询费率库&lt;/b&gt;&lt;br&gt;&lt;br&gt;rate_db (27 条真实费率)&lt;br&gt;按 起点+终点+币种 匹配&lt;br&gt;&lt;br&gt;费率来源:&lt;br&gt;1-②-2/3 邮件 + 2-④ 文件&lt;br&gt;(Nakamura S/R 已确认)" vertex="1">
          <mxGeometry x="550" y="540" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- AI Step 4: 填入 -->
        <mxCell id="a4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;④ 自动填入 Excel&lt;/b&gt;&lt;br&gt;&lt;br&gt;pkg_filler.py&lt;br&gt;逐行写入：&lt;br&gt;• E 列 単価&lt;br&gt;• F 列 Lead Time&lt;br&gt;• G 列 Carrier&amp;Route&lt;br&gt;• H 列 備考" vertex="1">
          <mxGeometry x="780" y="540" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- AI Step 5: 确认 -->
        <mxCell id="a5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;⑤ 营业审核&lt;/b&gt;&lt;br&gt;&lt;br&gt;页面显示填入详情&lt;br&gt;每条航线标记：&lt;br&gt;• 高/中/低置信度&lt;br&gt;• 填入/无费率/已有&lt;br&gt;&lt;br&gt;(25/26 = 96% 填入率)" vertex="1">
          <mxGeometry x="1010" y="540" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- AI Step 6: 下载 -->
        <mxCell id="a6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;⑥ 下载&amp;回传&lt;/b&gt;&lt;br&gt;&lt;br&gt;下载 filled_xxx.xlsx&lt;br&gt;内容与 2-④ 一致&lt;br&gt;&lt;br&gt;营业检查后&lt;br&gt;直接回传客户" vertex="1">
          <mxGeometry x="1240" y="540" width="200" height="150" as="geometry" />
        </mxCell>

        <!-- 时间轴提示 -->
        <mxCell id="a_time" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#2E7D32;" value="↑ 全程 &lt;1 分钟（只保留了最后的人工审核环节）↑" vertex="1">
          <mxGeometry x="400" y="720" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- 价值提示 -->
        <mxCell id="a_value" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#558B2F;fontSize=11;arcSize=10;" value="&lt;b&gt;价值:&lt;/b&gt; ① 消除询价等待 ② 费率库沉淀可复用 ③ 填入零失误 ④ 自动识别格式 ⑤ 营业只需做审核决策（非体力劳动）" vertex="1">
          <mxGeometry x="90" y="760" width="1350" height="50" as="geometry" />
        </mxCell>

        <!-- 箭头连接 -->
        <mxCell id="a_a1" parent="1" style="endArrow=classic;html=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" source="a1" target="a2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_a2" parent="1" style="endArrow=classic;html=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" source="a2" target="a3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_a3" parent="1" style="endArrow=classic;html=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" source="a3" target="a4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_a4" parent="1" style="endArrow=classic;html=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" source="a4" target="a5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_a5" parent="1" style="endArrow=classic;html=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" source="a5" target="a6"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 底部脚注 -->
        <mxCell id="footer" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666;fontStyle=2;" value="说明: 当前 Demo 的费率库是从 Customer A 的历史邮件与最终文件(2-④)中预先构建的 27 条真实费率。真实上线时，费率库应由每次询价后沉淀积累。" vertex="1">
          <mxGeometry x="60" y="860" width="1580" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="2. 系统内部数据流" id="page2">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title2" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#1A237E&quot;&gt;系统内部数据流 — 文件 → 解析 → 匹配 → 填入&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px;font-weight:normal;&quot; color=&quot;#666&quot;&gt;对应后端 4 个核心模块&lt;/font&gt;" vertex="1">
          <mxGeometry x="350" y="20" width="1000" height="60" as="geometry" />
        </mxCell>

        <!-- ====== 输入文件 ====== -->
        <mxCell id="input_file" parent="1" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;fontStyle=1;size=20;" value="&lt;b&gt;输入：2-①.xlsx&lt;/b&gt;&lt;br&gt;&lt;br&gt;客户空白入札模板&lt;br&gt;ミマキ Customer A&lt;br&gt;&lt;br&gt;5 段发地 × 26 航线" vertex="1">
          <mxGeometry x="80" y="150" width="200" height="170" as="geometry" />
        </mxCell>

        <!-- ====== 模块 1: parser ====== -->
        <mxCell id="mod1_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;verticalAlign=top;fontSize=14;fontStyle=1;arcSize=5;" value="Module 1: pkg_parser.py" vertex="1">
          <mxGeometry x="340" y="120" width="280" height="240" as="geometry" />
        </mxCell>
        <mxCell id="mod1_desc" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;" value="&lt;b&gt;职责：&lt;/b&gt;解析 Excel 结构&lt;br&gt;&lt;br&gt;&lt;b&gt;技术：&lt;/b&gt;openpyxl + 正则&lt;br&gt;&lt;br&gt;&lt;b&gt;输出：&lt;/b&gt;&lt;br&gt;• SectionInfo × 5&lt;br&gt;&amp;nbsp;&amp;nbsp;(发地段: 日/中/台/蘭/韓)&lt;br&gt;• LaneInfo × 26&lt;br&gt;&amp;nbsp;&amp;nbsp;(起点/终点/币种/类型)&lt;br&gt;&lt;br&gt;&lt;b&gt;关键逻辑：&lt;/b&gt;&lt;br&gt;• 识别表头行（&quot;発地&quot;+&quot;着地&quot;）&lt;br&gt;• 从表头提取币种&lt;br&gt;• 映射地名→IATA 代码" vertex="1">
          <mxGeometry x="360" y="155" width="250" height="200" as="geometry" />
        </mxCell>

        <!-- ====== 模块 2: rate_db ====== -->
        <mxCell id="mod2_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2;verticalAlign=top;fontSize=14;fontStyle=1;arcSize=5;" value="Module 2: rate_db.py" vertex="1">
          <mxGeometry x="680" y="120" width="280" height="240" as="geometry" />
        </mxCell>
        <mxCell id="mod2_desc" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;" value="&lt;b&gt;职责：&lt;/b&gt;费率数据库 + 查询&lt;br&gt;&lt;br&gt;&lt;b&gt;数据来源：&lt;/b&gt;&lt;br&gt;• 1-②-2.msg (Yang Jie 成本)&lt;br&gt;• 1-②-3.msg (Nakamura S/R)&lt;br&gt;• 2-④.xlsx (最终填入值)&lt;br&gt;&lt;br&gt;&lt;b&gt;规模：&lt;/b&gt;27 条真实费率&lt;br&gt;&lt;br&gt;&lt;b&gt;查询接口：&lt;/b&gt;&lt;br&gt;query_rate(&lt;br&gt;&amp;nbsp;&amp;nbsp;origin_code,&lt;br&gt;&amp;nbsp;&amp;nbsp;dest_code,&lt;br&gt;&amp;nbsp;&amp;nbsp;currency,&lt;br&gt;&amp;nbsp;&amp;nbsp;cost_type)" vertex="1">
          <mxGeometry x="700" y="155" width="250" height="200" as="geometry" />
        </mxCell>

        <!-- ====== 模块 3: filler ====== -->
        <mxCell id="mod3_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=top;fontSize=14;fontStyle=1;arcSize=5;" value="Module 3: pkg_filler.py" vertex="1">
          <mxGeometry x="1020" y="120" width="280" height="240" as="geometry" />
        </mxCell>
        <mxCell id="mod3_desc" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=none;strokeColor=none;" value="&lt;b&gt;职责：&lt;/b&gt;Excel 写入 + 状态标记&lt;br&gt;&lt;br&gt;&lt;b&gt;流程：&lt;/b&gt;&lt;br&gt;1. copy 输入文件到输出&lt;br&gt;2. 遍历每条 Lane&lt;br&gt;3. 调用 rate_db 查询&lt;br&gt;4. 写入 E/F/G/H 列&lt;br&gt;5. 记录填入状态&lt;br&gt;&lt;br&gt;&lt;b&gt;状态类型：&lt;/b&gt;&lt;br&gt;• filled (已填入)&lt;br&gt;• no_rate (无匹配)&lt;br&gt;• already_filled (已有数据)&lt;br&gt;• skipped (跳过)" vertex="1">
          <mxGeometry x="1040" y="155" width="250" height="200" as="geometry" />
        </mxCell>

        <!-- ====== 模块 4: API ====== -->
        <mxCell id="mod4_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#AD1457;strokeWidth=2;verticalAlign=top;fontSize=14;fontStyle=1;arcSize=5;" value="Module 4: api/v1/pkg.py (FastAPI)" vertex="1">
          <mxGeometry x="340" y="400" width="960" height="150" as="geometry" />
        </mxCell>

        <mxCell id="ep1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#AD1457;fontSize=11;arcSize=10;" value="&lt;b&gt;POST /pkg/upload&lt;/b&gt;&lt;br&gt;文件上传 + 解析&lt;br&gt;返回 session_id" vertex="1">
          <mxGeometry x="360" y="435" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ep2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#AD1457;fontSize=11;arcSize=10;" value="&lt;b&gt;POST /pkg/fill/&#123;id&#125;&lt;/b&gt;&lt;br&gt;触发自动填入&lt;br&gt;返回统计结果" vertex="1">
          <mxGeometry x="560" y="435" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ep3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#AD1457;fontSize=11;arcSize=10;" value="&lt;b&gt;GET /pkg/download/&#123;id&#125;&lt;/b&gt;&lt;br&gt;下载填入完成文件&lt;br&gt;(FileResponse)" vertex="1">
          <mxGeometry x="760" y="435" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ep4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#AD1457;fontSize=11;arcSize=10;" value="&lt;b&gt;GET /pkg/rates&lt;/b&gt;&lt;br&gt;查看费率库&lt;br&gt;(27 条)" vertex="1">
          <mxGeometry x="960" y="435" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ep5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#AD1457;fontSize=11;arcSize=10;" value="&lt;b&gt;Session 管理&lt;/b&gt;&lt;br&gt;内存 dict (Demo 用)&lt;br&gt;重启即失" vertex="1">
          <mxGeometry x="1160" y="435" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- ====== 输出文件 ====== -->
        <mxCell id="output_file" parent="1" style="shape=note;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#33691E;fontSize=12;fontStyle=1;size=20;" value="&lt;b&gt;输出：filled_xxx.xlsx&lt;/b&gt;&lt;br&gt;&lt;br&gt;E/F/G/H 列已填入&lt;br&gt;等同于 2-④.xlsx&lt;br&gt;&lt;br&gt;填入率 25/26 = 96%&lt;br&gt;置信度 ≥ 95%" vertex="1">
          <mxGeometry x="1410" y="150" width="200" height="170" as="geometry" />
        </mxCell>

        <!-- ====== 前端 ====== -->
        <mxCell id="fe_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;verticalAlign=top;fontSize=14;fontStyle=1;arcSize=5;" value="Frontend: PkgAutoFill.tsx (React + Ant Design)" vertex="1">
          <mxGeometry x="340" y="610" width="960" height="160" as="geometry" />
        </mxCell>
        <mxCell id="fe_step0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#F57F17;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;Step 0 上传&lt;/b&gt;&lt;br&gt;&lt;br&gt;Upload.Dragger&lt;br&gt;拖拽 .xlsx&lt;br&gt;&lt;br&gt;→ POST /pkg/upload" vertex="1">
