        <mxCell id="f3" parent="1" style="endArrow=classic;html=1;strokeColor=#6A1B9A;strokeWidth=2;dashed=1;" edge="1" source="mod2_box" target="mod3_box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
