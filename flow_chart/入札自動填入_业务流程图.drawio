        <mxCell id="fe_step1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#F57F17;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;Step 1 确认解析&lt;/b&gt;&lt;br&gt;&lt;br&gt;Collapse 展示 5 段&lt;br&gt;Table 展示 26 航线&lt;br&gt;&lt;br&gt;按钮: 自動填入" vertex="1">
          <mxGeometry x="600" y="645" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="fe_step2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#F57F17;fontSize=11;arcSize=10;verticalAlign=top;" value="&lt;b&gt;Step 2 结果展示&lt;/b&gt;&lt;br&gt;&lt;br&gt;Statistic 统计卡&lt;br&gt;Table 填入详情&lt;br&gt;置信度颜色标记&lt;br&gt;&lt;br&gt;→ 下载 filled 文件" vertex="1">
          <mxGeometry x="840" y="645" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="fe_api" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#F57F17;fontSize=10;arcSize=10;verticalAlign=top;fontStyle=2;" value="services/api.ts&lt;br&gt;&lt;br&gt;pkgApi.upload()&lt;br&gt;pkgApi.fill()&lt;br&gt;pkgApi.downloadUrl()" vertex="1">
          <mxGeometry x="1080" y="645" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- 数据流箭头 -->
        <mxCell id="f1" parent="1" style="endArrow=classic;html=1;strokeColor=#333;strokeWidth=2;" edge="1" source="input_file" target="mod1_box">
