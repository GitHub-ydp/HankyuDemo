        <mxCell id="f_label" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#6A1B9A;fontStyle=2;fillColor=none;strokeColor=none;" value="查询费率" vertex="1">
          <mxGeometry x="960" y="365" width="80" height="20" as="geometry" />
