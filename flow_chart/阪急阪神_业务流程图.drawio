          <mxGeometry x="1100" y="100" width="280" height="180" as="geometry" />
        </mxCell>
        <mxCell id="compare_title" value="&lt;b&gt;预期效果&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#6A1B9A;" vertex="1" parent="1">
          <mxGeometry x="1190" y="105" width="90" height="30" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="✓ 耗时: 数天 → 分钟" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="1120" y="140" width="140" height="25" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="✓ 准确率: → 接近100%" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#2E7D32;" vertex="1" parent="1">
