  <diagram name="1. 现行业务流程（AS-IS）" id="_sc-9VpTgurrqdewT-Lu">
    <mxGraphModel dx="1295" dy="761" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" value="&lt;b&gt;现行投标业务流程（AS-IS）&lt;/b&gt;&lt;br&gt;全程人工操作 — 效率低、易出错、投标成功率仅 0%~10%" vertex="1">
          <mxGeometry height="50" width="600" x="400" y="20" as="geometry" />
        </mxCell>
        <mxCell id="customer" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" value="&lt;b&gt;客户&lt;/b&gt;&lt;br&gt;(ABC Co 等)" vertex="1">
          <mxGeometry height="60" width="40" x="80" y="200" as="geometry" />
        </mxCell>
        <mxCell id="step1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=20;" value="&lt;b&gt;1. 发送投标包&lt;/b&gt;&lt;br&gt;(PKG)" vertex="1">
          <mxGeometry height="60" width="160" x="200" y="200" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="customer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;" target="step1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=20;" value="&lt;b&gt;2. 人工查询费率&lt;/b&gt;&lt;br&gt;从采购部门 &amp; 费率表(Tariff)&lt;br&gt;确认汇率" vertex="1">
          <mxGeometry height="60" width="200" x="440" y="200" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="step1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;strokeWidth=2;" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="procurement" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" value="&lt;b&gt;采购部门&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="120" x="400" y="100" as="geometry" />
        </mxCell>
        <mxCell id="tariff" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" value="&lt;b&gt;费率表 Tariff&lt;/b&gt;&lt;br&gt;(Excel)" vertex="1">
          <mxGeometry height="60" width="120" x="550" y="90" as="geometry" />
        </mxCell>
        <mxCell id="e_proc" edge="1" parent="1" source="procurement" style="dashed=1;strokeColor=#b85450;strokeWidth=1;" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tariff" edge="1" parent="1" source="tariff" style="dashed=1;strokeColor=#b85450;strokeWidth=1;" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=20;" value="&lt;b&gt;3. 逐航线填写&lt;/b&gt;&lt;br&gt;按 Lane 逐一确认费率&lt;br&gt;手动填入投标文件" vertex="1">
          <mxGeometry height="60" width="200" x="720" y="200" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="step2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;strokeWidth=2;" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=20;" value="&lt;b&gt;4. 人工检查&lt;/b&gt;&lt;br&gt;核对数据准确性" vertex="1">
          <mxGeometry height="60" width="160" x="1000" y="200" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="step3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;strokeWidth=2;" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=20;" value="&lt;b&gt;5. 提交&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="1240" y="200" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="step4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;strokeWidth=2;" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pain_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#CC0000;" value="&lt;b&gt;核心痛点&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="100" x="80" y="340" as="geometry" />
        </mxCell>
        <mxCell id="pain1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" value="&lt;font color=&quot;#CC0000&quot;&gt;✖&lt;/font&gt; 工作量巨大：逐航线报价，航线范围极广" vertex="1">
          <mxGeometry height="35" width="340" x="80" y="380" as="geometry" />
        </mxCell>
        <mxCell id="pain2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" value="&lt;font color=&quot;#CC0000&quot;&gt;✖&lt;/font&gt; 费率频繁变动：随季节和时期波动，需反复确认" vertex="1">
          <mxGeometry height="35" width="340" x="80" y="425" as="geometry" />
        </mxCell>
        <mxCell id="pain3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" value="&lt;font color=&quot;#CC0000&quot;&gt;✖&lt;/font&gt; 信息维度多：费率+航司+船司+中转时间+服务等级" vertex="1">
          <mxGeometry height="35" width="340" x="80" y="470" as="geometry" />
        </mxCell>
        <mxCell id="pain4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" value="&lt;font color=&quot;#CC0000&quot;&gt;✖&lt;/font&gt; 投入产出比极低：投标成功率仅 0%~10%" vertex="1">
          <mxGeometry height="35" width="340" x="480" y="380" as="geometry" />
        </mxCell>
        <mxCell id="pain5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" value="&lt;font color=&quot;#CC0000&quot;&gt;✖&lt;/font&gt; 人工操作易出错：手工录入导致费率数值错误" vertex="1">
          <mxGeometry height="35" width="340" x="480" y="425" as="geometry" />
        </mxCell>
        <mxCell id="pain6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" value="&lt;font color=&quot;#CC0000&quot;&gt;✖&lt;/font&gt; 未必转化为业务：成功提交也未必全部转化为实际业务" vertex="1">
          <mxGeometry height="35" width="340" x="480" y="470" as="geometry" />
        </mxCell>
        <mxCell id="lane_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" value="&lt;b&gt;航线示例（Lane）&lt;/b&gt;&lt;br&gt;&lt;br&gt;成田 → 上海&lt;br&gt;成田 → 香港&lt;br&gt;大阪 → 深圳&lt;br&gt;名古屋 → 广州&lt;br&gt;... (数百条)" vertex="1">
          <mxGeometry height="170" width="160" x="900" y="340" as="geometry" />
        </mxCell>
        <mxCell id="time_bar" parent="1" style="shape=doubleArrow;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arrowWidth=0.3;arrowSize=0.3;" value="&lt;b&gt;耗时：数小时 ~ 数天&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="520" x="440" y="290" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="2. AI导入后业务流程（TO-BE）" id="OIxCwOHNSiT6FLZJYmhJ">
