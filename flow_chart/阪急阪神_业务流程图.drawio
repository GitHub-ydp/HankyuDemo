          <mxGeometry x="360" y="150" width="80" height="45" as="geometry" />
        </mxCell>
        <!-- Procurement -->
        <mxCell id="pt_proc" value="&lt;b&gt;采购部门&lt;/b&gt;&lt;br&gt;获取最新费率和服务信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#F57C00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="230" width="170" height="50" as="geometry" />
        </mxCell>
        <!-- Tariff DB -->
