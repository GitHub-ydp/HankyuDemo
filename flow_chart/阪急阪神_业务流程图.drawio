        <mxCell id="title2" value="&lt;b&gt;AI 导入后投标业务流程（TO-BE）&lt;/b&gt;&lt;br&gt;AI 自动提取费率 + 自动填写投标包 — 分钟级完成" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" vertex="1" parent="1">
