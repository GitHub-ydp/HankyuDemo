          <mxGeometry x="60" y="150" width="90" height="45" as="geometry" />
        </mxCell>
        <mxCell id="ds_ship" value="&lt;b&gt;船运公司&lt;/b&gt;&lt;br&gt;(Shipping)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="150" width="90" height="45" as="geometry" />
        </mxCell>
        <mxCell id="ds_coloader" value="&lt;b&gt;联运商&lt;/b&gt;&lt;br&gt;(Co-loader)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="150" width="90" height="45" as="geometry" />
        </mxCell>
