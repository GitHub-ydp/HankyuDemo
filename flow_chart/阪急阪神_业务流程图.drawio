        <mxCell id="e_proc_tariff" value="维护&amp;更新" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F57C00;strokeWidth=2;fontSize=10;" edge="1" source="pt_proc" target="pt_tariff" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Rate Publish -->
        <mxCell id="pt_publish" value="&lt;b&gt;费率公开&lt;/b&gt;&lt;br&gt;现地法人 &amp; 代理店" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#F57C00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="370" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e_publish" style="dashed=1;strokeColor=#F57C00;" edge="1" source="pt_tariff" target="pt_publish" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- AI System Box -->
        <mxCell id="ai_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;dashed=0;arcSize=8;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="520" y="100" width="520" height="360" as="geometry" />
        </mxCell>
        <mxCell id="ai_label" value="&lt;b&gt;AI 自动化系统&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="690" y="105" width="150" height="30" as="geometry" />
        </mxCell>
        <!-- Customer PKG Input -->
        <mxCell id="cust_pkg" value="&lt;b&gt;客户投标包&lt;/b&gt;&lt;br&gt;(PKG)&lt;br&gt;Excel / PDF" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#BBDEFB;strokeColor=#1976D2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="150" width="120" height="70" as="geometry" />
        </mxCell>
        <!-- AI Step 1: Parse -->
        <mxCell id="ai_parse" value="&lt;b&gt;parse_pkg&lt;/b&gt;&lt;br&gt;解析投标包结构&lt;br&gt;识别需填写字段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#4CAF50;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="150" height="55" as="geometry" />
        </mxCell>
        <!-- AI Step 2: Query -->
        <mxCell id="ai_query" value="&lt;b&gt;query_rate&lt;/b&gt;&lt;br&gt;按航线自动查询&lt;br&gt;最新费率" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#4CAF50;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="880" y="150" width="140" height="55" as="geometry" />
        </mxCell>
        <!-- AI Step 3: Fill -->
        <mxCell id="ai_fill" value="&lt;b&gt;fill_pkg&lt;/b&gt;&lt;br&gt;自动填入费率数据&lt;br&gt;到投标包对应栏位" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#4CAF50;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="240" width="160" height="55" as="geometry" />
        </mxCell>
        <!-- AI Step 4: Validate -->
        <mxCell id="ai_validate" value="&lt;b&gt;validate_rate&lt;/b&gt;&lt;br&gt;校验费率合理性&lt;br&gt;(历史数据比对)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#4CAF50;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="890" y="240" width="140" height="55" as="geometry" />
        </mxCell>
        <!-- AI Step 5: Notify -->
        <mxCell id="ai_notify" value="&lt;b&gt;notify&lt;/b&gt;&lt;br&gt;通知营业人员审核" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#4CAF50;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="330" width="150" height="45" as="geometry" />
        </mxCell>
        <!-- Arrows within AI -->
        <mxCell id="ea1" style="strokeColor=#4CAF50;strokeWidth=2;" edge="1" source="cust_pkg" target="ai_parse" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea2" style="strokeColor=#4CAF50;strokeWidth=2;" edge="1" source="ai_parse" target="ai_query" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea3" style="strokeColor=#4CAF50;strokeWidth=2;" edge="1" source="ai_query" target="ai_fill" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea4" style="strokeColor=#4CAF50;strokeWidth=2;" edge="1" source="ai_fill" target="ai_validate" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea5" style="strokeColor=#4CAF50;strokeWidth=2;" edge="1" source="ai_validate" target="ai_notify" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Connection: Tariff to AI Query -->
        <mxCell id="e_tariff_ai" value="自动提取费率" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#FF9800;strokeWidth=2;fontSize=10;dashed=1;dashPattern=8 4;" edge="1" source="pt_tariff" target="ai_query" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Sales Person -->
