        <mxCell id="ds4_f3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=9;align=left;spacingLeft=8;" value="&lt;b&gt;特点：&lt;/b&gt;图片格式，含中文口语表达，信息零散但含关键费率" vertex="1">
