          <mxGeometry x="460" y="110" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="eds1_p1" parent="1" style="rounded=1;strokeColor=#283593;strokeWidth=2;exitX=1;exitY=0.3;entryX=0;entryY=0.5;" edge="1" source="ds1_box" target="parse1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 难点标注 -->
        <mxCell id="ds1_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;spacingLeft=5;" value="&lt;b&gt;难点：&lt;/b&gt;&lt;br&gt;• 不同供应商列结构不同&lt;br&gt;• Excel含公式引用（=F6）&lt;br&gt;• 中文编码问题" vertex="1">
