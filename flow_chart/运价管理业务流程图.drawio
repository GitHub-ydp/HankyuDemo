<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6" pages="4">
  <diagram name="1. 运价获取现行流程（AS-IS）" id="tariff-asis">
    <mxGraphModel dx="1554" dy="913" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t1" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;" value="&lt;font color=&quot;#333&quot;&gt;运价获取现行流程（AS-IS）&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;font-weight:normal;&quot; color=&quot;#999&quot;&gt;购买部门从约15~20家供应商获取运价，手动录入Excel — 约每2周更新一次&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="1000" x="300" y="15" as="geometry" />
        </mxCell>
        <mxCell id="supplier_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;arcSize=8;" value="供应商（约15~20家）" vertex="1">
          <mxGeometry height="520" width="280" x="40" y="80" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#fff;" value="&lt;b&gt;船司（船运公司）&lt;/b&gt;&lt;br&gt;ONE, KMTC, Evergreen&lt;br&gt;OOCL, EMC 等" vertex="1">
          <mxGeometry height="70" width="220" x="70" y="130" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#fff;" value="&lt;b&gt;联运商（Co-loader）&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="220" x="70" y="220" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;fontColor=#fff;" value="&lt;b&gt;代理店&lt;/b&gt;&lt;br&gt;Agent" vertex="1">
          <mxGeometry height="60" width="220" x="70" y="300" as="geometry" />
        </mxCell>
        <mxCell id="ch_title" parent="1" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#666;" value="获取渠道多样" vertex="1">
          <mxGeometry height="30" width="220" x="70" y="380" as="geometry" />
        </mxCell>
        <mxCell id="ch1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=10;" value="📧 邮件 Email&lt;br&gt;（Excel/PDF 附件）" vertex="1">
          <mxGeometry height="45" width="100" x="70" y="415" as="geometry" />
        </mxCell>
        <mxCell id="ch2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=10;" value="💬 WeChat / QQ&lt;br&gt;（文字/截图）" vertex="1">
          <mxGeometry height="45" width="100" x="190" y="415" as="geometry" />
        </mxCell>
        <mxCell id="ch3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=10;" value="📄 邮件正文&lt;br&gt;（纯文字报价）" vertex="1">
          <mxGeometry height="45" width="100" x="70" y="475" as="geometry" />
        </mxCell>
        <mxCell id="ch4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=10;" value="📋 PDF 合约&lt;br&gt;（如ONE 372页）" vertex="1">
          <mxGeometry height="45" width="100" x="190" y="475" as="geometry" />
        </mxCell>
        <mxCell id="proc_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;arcSize=8;" value="购买部门（Procurement）" vertex="1">
          <mxGeometry height="520" width="460" x="420" y="80" as="geometry" />
        </mxCell>
        <mxCell id="e_s_p" edge="1" parent="1" source="supplier_box" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9C27B0;strokeWidth=3;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" target="proc_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_s_p_label" connectable="0" parent="e_s_p" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#9C27B0;fontStyle=1;" value="多渠道发送运价&lt;br&gt;邮件/WeChat/QQ等" vertex="1">
          <mxGeometry relative="1" x="-0.1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;arcSize=15;" value="&lt;b&gt;① 接收运价&lt;/b&gt;&lt;br&gt;从邮件/WeChat/QQ&lt;br&gt;收集各供应商报价" vertex="1">
          <mxGeometry height="65" width="170" x="450" y="140" as="geometry" />
        </mxCell>
        <mxCell id="p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;arcSize=15;" value="&lt;b&gt;② 人工阅读&lt;/b&gt;&lt;br&gt;逐条阅读各格式的&lt;br&gt;运价信息" vertex="1">
          <mxGeometry height="65" width="170" x="450" y="230" as="geometry" />
        </mxCell>
        <mxCell id="p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8A65;strokeColor=#BF360C;fontSize=11;arcSize=15;fontColor=#fff;" value="&lt;b&gt;③ 手动录入 Excel ⚠️&lt;/b&gt;&lt;br&gt;逐条手打输入到&lt;br&gt;运价管理表&lt;br&gt;（最大痛点）" vertex="1">
          <mxGeometry height="75" width="170" x="450" y="320" as="geometry" />
        </mxCell>
        <mxCell id="p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;arcSize=15;" value="&lt;b&gt;④ 核对检查&lt;/b&gt;&lt;br&gt;确认录入数据&lt;br&gt;的准确性" vertex="1">
          <mxGeometry height="65" width="170" x="450" y="420" as="geometry" />
        </mxCell>
        <mxCell id="ep12" edge="1" parent="1" source="p1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;" target="p2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep23" edge="1" parent="1" source="p2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;" target="p3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep34" edge="1" parent="1" source="p3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;" target="p4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="excel_master" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=12;fontStyle=1;" value="运价管理表&lt;br&gt;（Excel）" vertex="1">
          <mxGeometry height="80" width="160" x="670" y="240" as="geometry" />
        </mxCell>
        <mxCell id="ep3x" edge="1" parent="1" source="p3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;dashed=1;" target="excel_master">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cycle_note" parent="1" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=15;position=0.5;base=20;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;rounded=1;" value="&lt;b&gt;约2周更新一次&lt;/b&gt;&lt;br&gt;每次需重新录入" vertex="1">
          <mxGeometry height="70" width="160" x="670" y="340" as="geometry" />
        </mxCell>
        <mxCell id="pain1" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;size=15;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontColor=#C62828;" value="&lt;b&gt;痛点&lt;/b&gt;：耗时" vertex="1">
          <mxGeometry height="40" width="100" x="660" y="140" as="geometry" />
        </mxCell>
        <mxCell id="pain2" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;size=15;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontColor=#C62828;" value="&lt;b&gt;痛点&lt;/b&gt;：易出错" vertex="1">
          <mxGeometry height="40" width="100" x="770" y="140" as="geometry" />
        </mxCell>
        <mxCell id="sales_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;arcSize=8;" value="营业部门（销售）" vertex="1">
          <mxGeometry height="520" width="310" x="960" y="80" as="geometry" />
        </mxCell>
        <mxCell id="sa1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;arcSize=15;" value="&lt;b&gt;① 收到客户投标包&lt;/b&gt;&lt;br&gt;(PKG)" vertex="1">
          <mxGeometry height="55" width="240" x="995" y="140" as="geometry" />
        </mxCell>
        <mxCell id="sa2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;arcSize=15;" value="&lt;b&gt;② 向购买部门请求报价&lt;/b&gt;&lt;br&gt;向各地购买担当发邮件请求报价" vertex="1">
          <mxGeometry height="55" width="240" x="995" y="220" as="geometry" />
        </mxCell>
        <mxCell id="sa3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;arcSize=15;" value="&lt;b&gt;③ 收到购买部门回复&lt;/b&gt;&lt;br&gt;购买部门通过邮件回复运价" vertex="1">
          <mxGeometry height="55" width="240" x="995" y="300" as="geometry" />
        </mxCell>
        <mxCell id="sa4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#90CAF9;strokeColor=#0D47A1;fontSize=11;arcSize=15;fontColor=#0D47A1;" value="&lt;b&gt;④ 手动填写投标包 ⚠️&lt;/b&gt;&lt;br&gt;按客户指定格式填入&lt;br&gt;逐航线填入费率" vertex="1">
          <mxGeometry height="65" width="240" x="995" y="380" as="geometry" />
        </mxCell>
        <mxCell id="sa5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;arcSize=15;" value="&lt;b&gt;⑤ 提交投标&lt;/b&gt;" vertex="1">
          <mxGeometry height="45" width="240" x="995" y="470" as="geometry" />
        </mxCell>
        <mxCell id="esa12" edge="1" parent="1" source="sa1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=2;" target="sa2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esa23" edge="1" parent="1" source="sa2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=2;" target="sa3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esa34" edge="1" parent="1" source="sa3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=2;" target="sa4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esa45" edge="1" parent="1" source="sa4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=2;" target="sa5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_proc_sales" edge="1" parent="1" source="excel_master" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#FF6F00;strokeWidth=2;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" target="sa3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_proc_sales_label" connectable="0" parent="e_proc_sales" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#FF6F00;" value="邮件回复费率" vertex="1">
          <mxGeometry relative="1" x="-0.2" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="customer" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" value="&lt;b&gt;客户&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="40" x="1380" y="130" as="geometry" />
        </mxCell>
        <mxCell id="e_cust_sa" edge="1" parent="1" source="customer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=2;" target="sa1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_sa_cust" edge="1" parent="1" source="sa5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;strokeWidth=2;exitX=1;exitY=0.5;entryX=1;entryY=1;" target="customer">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1430" y="493" />
              <mxPoint x="1430" y="190" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_sa_cust_label" connectable="0" parent="e_sa_cust" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#2E7D32;fontStyle=1;" value="提交投标" vertex="1">
          <mxGeometry relative="1" x="-0.3" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="summary" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=10;fontColor=#B71C1C;align=left;spacingLeft=15;" value="&lt;b&gt;现行流程痛点总结：&lt;/b&gt;&lt;br&gt;• 供应商 15~20 社 × 多渠道（邮件/WeChat/QQ）× 多格式（Excel/PDF/文本/截图）→ 信息碎片化&lt;br&gt;• 购买部门手动录入 Excel → 耗时大、更新慢（2周/次）、易出错&lt;br&gt;• 营业部门手动填写 PKG → 逐航线逐条填入，重复劳动&lt;br&gt;• 投标成功率仅 0%~10% → 投入产出比极低" vertex="1">
          <mxGeometry height="90" width="1230" x="40" y="640" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="2. AI自动化运价管理（TO-BE）" id="tariff-tobe">
    <mxGraphModel dx="1400" dy="860" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- 标题 -->
        <mxCell id="t2" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;" value="&lt;font color=&quot;#333&quot;&gt;AI自动化运价管理流程（TO-BE）&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;font-weight:normal;&quot; color=&quot;#999&quot;&gt;AI从邮件、WeChat、PDF、Excel自动读取运价 → 存入数据库 → 自动填写投标包&lt;/font&gt;" vertex="1">
          <mxGeometry x="250" y="15" width="1100" height="50" as="geometry" />
        </mxCell>
        <!-- ====== 第1列：数据来源 ====== -->
        <mxCell id="src_title" parent="1" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=13;fontStyle=1;fontColor=#6A1B9A;" value="数据来源" vertex="1">
          <mxGeometry x="40" y="75" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="src1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;" value="&lt;b&gt;Excel 费率表&lt;/b&gt;&lt;br&gt;KMTC运价表、NVO FAK等" vertex="1">
          <mxGeometry x="40" y="115" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="src2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;" value="&lt;b&gt;PDF 合约&lt;/b&gt;&lt;br&gt;ONE Service Contract 等" vertex="1">
          <mxGeometry x="40" y="185" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="src3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;" value="&lt;b&gt;邮件纯文本&lt;/b&gt;&lt;br&gt;长荣等代理商报价邮件" vertex="1">
          <mxGeometry x="40" y="255" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="src4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;" value="&lt;b&gt;WeChat/QQ 截图&lt;/b&gt;&lt;br&gt;聊天中的运价截图" vertex="1">
          <mxGeometry x="40" y="325" width="200" height="55" as="geometry" />
        </mxCell>
        <!-- ====== 第2列：上传入口 ====== -->
        <mxCell id="upload" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;arcSize=15;strokeWidth=2;" value="统一上传入口&lt;br&gt;&lt;font style=&quot;font-size:10px;font-weight:normal;&quot;&gt;购买人员上传文件&lt;br&gt;（Excel / PDF / 图片 / 文本）&lt;/font&gt;" vertex="1">
          <mxGeometry x="320" y="170" width="180" height="100" as="geometry" />
        </mxCell>
        <!-- 来源→上传 箭头 -->
        <mxCell id="es1u" parent="1" style="rounded=1;strokeColor=#7B1FA2;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.2;" edge="1" source="src1" target="upload">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es2u" parent="1" style="rounded=1;strokeColor=#7B1FA2;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.4;" edge="1" source="src2" target="upload">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es3u" parent="1" style="rounded=1;strokeColor=#7B1FA2;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.6;" edge="1" source="src3" target="upload">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es4u" parent="1" style="rounded=1;strokeColor=#7B1FA2;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.8;" edge="1" source="src4" target="upload">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ====== 第3列：AI 解析引擎 ====== -->
        <mxCell id="ai_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;arcSize=8;" value="AI 解析引擎（OpenClaw）" vertex="1">
          <mxGeometry x="580" y="80" width="340" height="370" as="geometry" />
        </mxCell>
        <mxCell id="eu_ai" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;strokeWidth=3;" edge="1" source="upload" target="ai_box">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ai1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;arcSize=12;" value="&lt;b&gt;parse_excel_tariff&lt;/b&gt;&lt;br&gt;pandas + openpyxl&lt;br&gt;自动识别列结构" vertex="1">
          <mxGeometry x="600" y="125" width="145" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ai2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;arcSize=12;" value="&lt;b&gt;parse_pdf_contract&lt;/b&gt;&lt;br&gt;pdfplumber + Claude&lt;br&gt;提取费率表区域" vertex="1">
          <mxGeometry x="600" y="200" width="145" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ai3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;arcSize=12;" value="&lt;b&gt;parse_email_text&lt;/b&gt;&lt;br&gt;Claude NLP&lt;br&gt;实体提取（航线+费率）" vertex="1">
          <mxGeometry x="600" y="275" width="145" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ai4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;arcSize=12;" value="&lt;b&gt;parse_wechat_image&lt;/b&gt;&lt;br&gt;Claude Vision&lt;br&gt;OCR + 结构化提取" vertex="1">
