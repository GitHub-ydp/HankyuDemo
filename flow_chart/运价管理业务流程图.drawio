        <!-- Schema 字段展示 -->
        <mxCell id="schema_detail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=9;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" value="&lt;b style=&quot;font-size:11px;&quot;&gt;freight_rate 标准字段&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table style=&quot;font-size:9px;border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;carrier&lt;/b&gt;&lt;/td&gt;&lt;td&gt;船司名&lt;/td&gt;&lt;td&gt;KMTC, ONE, EMC&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;origin&lt;/b&gt;&lt;/td&gt;&lt;td&gt;起运港&lt;/td&gt;&lt;td&gt;CNSHA, CNNGB&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;destination&lt;/b&gt;&lt;/td&gt;&lt;td&gt;目的港&lt;/td&gt;&lt;td&gt;KRPUS, USLAX&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;20GP/40GP/40HQ&lt;/b&gt;&lt;/td&gt;&lt;td&gt;运费&lt;/td&gt;&lt;td&gt;USD&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;BAF/LSS&lt;/b&gt;&lt;/td&gt;&lt;td&gt;附加费&lt;/td&gt;&lt;td&gt;USD&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;valid_from/to&lt;/b&gt;&lt;/td&gt;&lt;td&gt;有效期&lt;/td&gt;&lt;td&gt;日期&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;transit_days&lt;/b&gt;&lt;/td&gt;&lt;td&gt;时效&lt;/td&gt;&lt;td&gt;天数&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;service_code&lt;/b&gt;&lt;/td&gt;&lt;td&gt;航线代码&lt;/td&gt;&lt;td&gt;KTX, CHT&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;remarks&lt;/b&gt;&lt;/td&gt;&lt;td&gt;备注&lt;/td&gt;&lt;td&gt;直达/中转&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry x="920" y="80" width="250" height="220" as="geometry" />
