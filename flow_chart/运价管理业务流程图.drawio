        <mxCell id="parse4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4FC3F7;strokeColor=#0277BD;fontSize=11;fontColor=#fff;fontStyle=1;arcSize=15;" value="parse_wechat_image&lt;br&gt;&lt;font style=&quot;font-weight:normal;font-size:10px;&quot;&gt;Claude Vision&lt;br&gt;多模态识别&lt;br&gt;OCR + 语义理解&lt;/font&gt;" vertex="1">
          <mxGeometry x="460" y="680" width="160" height="80" as="geometry" />
