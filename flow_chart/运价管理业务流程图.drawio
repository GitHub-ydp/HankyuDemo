          <mxGeometry x="460" y="500" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="eds3_p3" parent="1" style="rounded=1;strokeColor=#1B5E20;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="ds3_box" target="parse3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ds3_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;spacingLeft=5;" value="&lt;b&gt;难点：&lt;/b&gt;&lt;br&gt;• 非结构化中文文本&lt;br&gt;• 费率格式不固定(375/750)&lt;br&gt;• 港口名缩写/别名" vertex="1">
          <mxGeometry x="460" y="590" width="160" height="70" as="geometry" />
        </mxCell>
        <!-- ====== 数据源4: 截图 ====== -->
        <mxCell id="ds4_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;arcSize=6;" value="数据源 ④：WeChat/QQ 聊天截图" vertex="1">
          <mxGeometry x="40" y="630" width="350" height="160" as="geometry" />
