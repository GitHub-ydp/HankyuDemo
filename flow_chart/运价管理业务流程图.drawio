        <mxCell id="ds3_f1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#1B5E20;fontSize=9;align=left;spacingLeft=8;" value="&lt;b&gt;长荣(Evergreen)第12周报价&lt;/b&gt;&lt;br&gt;&quot;胡志明卡莱：375/750，胡志明VICT/盖美600/1100；&lt;br&gt;香港 225/450；泰国CTX0346:林查班550/1100...&quot;" vertex="1">
