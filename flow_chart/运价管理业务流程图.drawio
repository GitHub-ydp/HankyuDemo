        <mxCell id="ds4_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;spacingLeft=5;" value="&lt;b&gt;难点：&lt;/b&gt;&lt;br&gt;• 图片质量参差&lt;br&gt;• 对话格式非表格&lt;br&gt;• 数字识别精度要求高" vertex="1">
