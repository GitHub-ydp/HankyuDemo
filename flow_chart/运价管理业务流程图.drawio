        <mxCell id="ds4_f1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=9;align=left;spacingLeft=8;" value="&lt;b&gt;截图1：KMTC 印度航线&lt;/b&gt;&lt;br&gt;POL:Shanghai → POD:ICD Ahmedabad&lt;br&gt;NHAVA SHEVA中转 | USD 1650/1700" vertex="1">
