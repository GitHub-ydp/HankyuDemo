# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hankyu_hanshin

# Redis（可选）
REDIS_URL=redis://localhost:6379/0

# 应用配置
APP_NAME=阪急阪神入札業務効率化システム
APP_ENV=development
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# AI Provider（vllm | anthropic）
AI_PROVIDER=vllm
AI_TIMEOUT_SECONDS=90
AI_AUTO_NO_THINK=true
AI_MAX_TOKENS_DEFAULT=512
AI_MAX_TOKENS_EXTRACT_JSON=1024
AI_MAX_TOKENS_CAP=1536

# vLLM 本地 / OpenAI-compatible
VLLM_BASE_URL=http://43.133.197.65:8000/v1
VLLM_API_KEY=your_vllm_api_key_here
VLLM_MODEL=qwen3.6-27b
VLLM_ENABLE_THINKING=false
VLLM_ENABLE_CHAT_TEMPLATE_KWARGS=true

# 图片压缩
AI_IMAGE_COMPRESS=true
AI_IMAGE_MAX_EDGE_PX=1280
AI_IMAGE_JPEG_QUALITY=85

# ===== 备用：阿里云百炼（回滚用；把 VLLM_* 指到下面三值并关掉 chat_template_kwargs）=====
# VLLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VLLM_API_KEY=your_dashscope_key_here
# VLLM_MODEL=qwen3.6-plus
# VLLM_ENABLE_CHAT_TEMPLATE_KWARGS=false
# AI_AUTO_NO_THINK=false

# 老 Qwen 字段保留以兼容历史 env（代码已不读取，仅防 pydantic 报错）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-plus

# ===== 备用：Anthropic（供后续设置页切换）=====
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 邮箱 IMAP（邮件 Demo）
EMAIL_IMAP_HOST=imap.qiye.aliyun.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=
EMAIL_PASSWORD=
